diff --git a/Makefile b/Makefile
index ef2deca..54ce8f2 100644
--- a/Makefile
+++ b/Makefile
@@ -333,6 +333,23 @@ else ifeq ($(platform), miyoo)
    SHARED := -shared -Wl,--no-undefined -Wl,--version-script=link.T
    FLAGS += -fomit-frame-pointer -ffast-math -march=armv5te -mtune=arm926ej-s
 
+# TrimUI Model S
+else ifeq ($(platform), trimui)
+   TARGET := $(TARGET_NAME)_libretro.so
+   CC = $(CROSS_COMPILE)gcc
+   CXX = $(CROSS_COMPILE)g++
+   AR = $(CROSS_COMPILE)ar
+   fpic := -fno-PIC
+   SHARED := -shared -Wl,--no-undefined -Wl,--version-script=link.T
+   FLAGS += -fomit-frame-pointer -ffast-math -mcpu=arm926ej-s -mtune=arm926ej-s -flto
+   LDFLAGS += -flto
+   CXXFLAGS += -std=c++11
+   CFLAGS += -std=gnu11
+   OPTIMIZE := -Ofast -DNDEBUG
+   ifeq (,$(DEBUG))
+      LDFLAGS += -s
+   endif
+
 # Windows MSVC 2017 all architectures
 else ifneq (,$(findstring windows_msvc2017,$(platform)))
 
@@ -565,10 +582,19 @@ all: $(TARGET)
 
 ifeq ($(DEBUG),1)
    FLAGS += -O0 -g
+else ifneq (,$(OPTIMIZE))
+   FLAGS += $(OPTIMIZE)
 else
    FLAGS += -O2 -DNDEBUG $(EXTRA_GCC_FLAGS)
 endif
 
+ifeq ($(PROFILE), GENERATE)
+   FLAGS  += -fprofile-generate=./profile/mednafen_pce_fast
+   LDFLAGS += -lgcov
+else ifeq ($(PROFILE), APPLY)
+   FLAGS  += -fprofile-use -fprofile-dir=../profile/mednafen_pce_fast -fbranch-probabilities
+endif
+
 ifneq (,$(findstring msvc,$(platform)))
 ifeq ($(DEBUG), 1)
    CFLAGS   += -MTd
